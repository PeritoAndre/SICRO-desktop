{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "SICRO 2.0",
  "version": "2.0.0-beta.0",
  "identifier": "br.org.sicro.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SICRO 2.0",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "center": true,
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "publisher": "Polícia Científica do Amapá",
    "copyright": "© 2026 Polícia Científica do Amapá",
    "licenseFile": "installer/termo-de-uso.txt",
    "shortDescription": "Suíte pericial SICRO 2.0",
    "longDescription": "Sistema Integrado de Criminalística e Operações — workspace pericial do perito criminal.",
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    }
  },
  "plugins": {}
}
