# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Node
node_modules
dist
dist-ssr
*.local

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust / Tauri
src-tauri/target/
src-tauri/gen/
# NOTE: Cargo.lock is intentionally NOT ignored — this crate is a binary
# (Tauri app), so the lockfile must be committed to guarantee reproducible
# builds across machines. See https://doc.rust-lang.org/cargo/faq.html.

# Build / runtime artifacts inside repo
*.sicro/
# pdf.js wasm (OpenJPEG/JBIG2) — copiado de node_modules/pdfjs-dist/wasm
# pelo vite.config a cada build/dev; gerado, não versionar.
public/pdfjs-wasm/

# Documentação interna (relatórios de MVP/Spike/auditoria) — fica só no disco,
# para uso da equipe; não é publicada no git. EXCEÇÃO: o manual do perito é
# importado no build (tela Ajuda: `import ... MANUAL_SICRO.md?raw`), então
# permanece versionado.
docs/*
!docs/MANUAL_SICRO.md
!docs/.gitkeep
*.tmp
*.bak

# SICRO test artifacts — NEVER commit real pericial data or test exports
*.sicrodoc
*.sicroapp
*.sicrocampo
*.sicrocroqui
*.sicroimage
*.sicrobackup
exports/
imagens/exports/
imagens/originais/
imagens/analises/
videos/originais/
videos/storyboards/
croquis/exports/
# MVP 9 — drone import derivatives + sidecars (background images
# generated by the drone wizard, plus their JSON sidecars). The
# `*.sicro/` rule above already covers anything inside a workspace,
# but these explicit patterns guard against accidental commits when
# a test artifact lands in the repo root or in a non-workspace path.
croquis/backgrounds/
**/drone_corrigido_*
**/*.sidecar.json
reports/
backups/
**/test-workspaces/
**/exportados-de-teste/
**/imports_index.json
# Sidecar JSON files that travel with derived images / frames
**/*_sidecar.json
# SQLite of any workspace
sicro.sqlite
sicro.sqlite-journal
sicro.sqlite-wal
sicro.sqlite-shm

# Video evidence — never commit real footage or per-frame test PNGs/JSON
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.m4v

# Design source files (keep only the rendered PNG/SVG in the repo)
*.psd
*.ai
*.bmp

# Env
.env
.env.local
.env.*.local
